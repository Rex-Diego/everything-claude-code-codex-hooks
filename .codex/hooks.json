{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"scripts/codex/codex-hook-runner.js\" script \"scripts/hooks/pre-bash-dispatcher.js\""
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"scripts/codex/codex-hook-runner.js\" run-with-flags \"pre:write:doc-file-warning\" \"scripts/hooks/doc-file-warning.js\" \"standard,strict\""
          }
        ],
        "matcher": "Write"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"scripts/codex/codex-hook-runner.js\" run-with-flags \"pre:edit-write:suggest-compact\" \"scripts/hooks/suggest-compact.js\" \"standard,strict\""
          }
        ],
        "matcher": "Edit|Write"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"scripts/codex/codex-hook-runner.js\" run-with-flags \"pre:observe\" \"scripts/hooks/observe-runner.js\" \"standard,strict\"",
            "timeout": 10
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"scripts/codex/codex-hook-runner.js\" run-with-flags \"pre:governance-capture\" \"scripts/hooks/governance-capture.js\" \"standard,strict\"",
            "timeout": 10
          }
        ],
        "matcher": "Bash|Write|Edit|MultiEdit"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"scripts/codex/codex-hook-runner.js\" run-with-flags \"pre:config-protection\" \"scripts/hooks/config-protection.js\" \"standard,strict\"",
            "timeout": 5
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"scripts/codex/codex-hook-runner.js\" run-with-flags \"pre:mcp-health-check\" \"scripts/hooks/mcp-health-check.js\" \"standard,strict\""
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"scripts/codex/codex-hook-runner.js\" run-with-flags \"pre:edit-write:gateguard-fact-force\" \"scripts/hooks/gateguard-fact-force.js\" \"standard,strict\"",
            "timeout": 5
          }
        ],
        "matcher": "Edit|Write|MultiEdit"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"scripts/codex/codex-hook-runner.js\" script \"scripts/hooks/session-start-bootstrap.js\""
          }
        ],
        "matcher": "*"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"scripts/codex/codex-hook-runner.js\" script \"scripts/hooks/post-bash-dispatcher.js\"",
            "timeout": 30
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"scripts/codex/codex-hook-runner.js\" run-with-flags \"post:quality-gate\" \"scripts/hooks/quality-gate.js\" \"standard,strict\"",
            "timeout": 30
          }
        ],
        "matcher": "Edit|Write|MultiEdit"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"scripts/codex/codex-hook-runner.js\" run-with-flags \"post:edit:design-quality-check\" \"scripts/hooks/design-quality-check.js\" \"standard,strict\"",
            "timeout": 10
          }
        ],
        "matcher": "Edit|Write|MultiEdit"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"scripts/codex/codex-hook-runner.js\" run-with-flags \"post:edit:accumulate\" \"scripts/hooks/post-edit-accumulator.js\" \"standard,strict\""
          }
        ],
        "matcher": "Edit|Write|MultiEdit"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"scripts/codex/codex-hook-runner.js\" run-with-flags \"post:edit:console-warn\" \"scripts/hooks/post-edit-console-warn.js\" \"standard,strict\""
          }
        ],
        "matcher": "Edit"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"scripts/codex/codex-hook-runner.js\" run-with-flags \"post:governance-capture\" \"scripts/hooks/governance-capture.js\" \"standard,strict\"",
            "timeout": 10
          }
        ],
        "matcher": "Bash|Write|Edit|MultiEdit"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"scripts/codex/codex-hook-runner.js\" run-with-flags \"post:session-activity-tracker\" \"scripts/hooks/session-activity-tracker.js\" \"standard,strict\"",
            "timeout": 10
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"scripts/codex/codex-hook-runner.js\" run-with-flags \"post:observe\" \"scripts/hooks/observe-runner.js\" \"standard,strict\"",
            "timeout": 10
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"scripts/codex/codex-hook-runner.js\" run-with-flags \"stop:format-typecheck\" \"scripts/hooks/stop-format-typecheck.js\" \"standard,strict\"",
            "timeout": 300
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"scripts/codex/codex-hook-runner.js\" run-with-flags \"stop:check-console-log\" \"scripts/hooks/check-console-log.js\" \"standard,strict\""
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"scripts/codex/codex-hook-runner.js\" run-with-flags \"stop:session-end\" \"scripts/hooks/session-end.js\" \"minimal,standard,strict\"",
            "timeout": 10
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"scripts/codex/codex-hook-runner.js\" run-with-flags \"stop:evaluate-session\" \"scripts/hooks/evaluate-session.js\" \"minimal,standard,strict\"",
            "timeout": 10
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"scripts/codex/codex-hook-runner.js\" run-with-flags \"stop:cost-tracker\" \"scripts/hooks/cost-tracker.js\" \"minimal,standard,strict\"",
            "timeout": 10
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"scripts/codex/codex-hook-runner.js\" run-with-flags \"stop:desktop-notify\" \"scripts/hooks/desktop-notify.js\" \"standard,strict\"",
            "timeout": 10
          }
        ],
        "matcher": "*"
      }
    ]
  }
}
